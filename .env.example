# ============================================================
# MySQL Source Database Connection
# ============================================================
# اگر MySQL روی هاست (خارج از Docker) اجرا می‌شود، از host.docker.internal
# استفاده کنید نه localhost (چون localhost داخل container به خود container
# اشاره می‌کند نه به هاست). اگر MySQL در یک container دیگر است، نام سرویس
# آن را در همان شبکه Docker وارد کنید.
MYSQL_HOST=mysql_old
MYSQL_PORT=3306
MYSQL_DATABASE=dbname
MYSQL_USER=dbuser
MYSQL_PASSWORD=dbpass

# ============================================================
# PostgreSQL Target Database Connection
# ============================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=dbname
POSTGRES_USER=dbuser
POSTGRES_PASSWORD=dbpass@2024

# ============================================================
# Migration Settings
# ============================================================

# تعداد رکوردهایی که در هر Batch منتقل می‌شوند
BATCH_SIZE=1000

# اگر true باشد، جداول مقصد قبل از migrate شدن DROP و دوباره CREATE می‌شوند
DROP_EXISTING_TABLES=false

# اگر true باشد، فقط ساختار (schema) منتقل می‌شود و داده‌ها منتقل نمی‌شوند
SCHEMA_ONLY=false

# اگر true باشد، فقط داده‌ها منتقل می‌شوند (فرض بر این است که schema از قبل ساخته شده)
DATA_ONLY=false

# لیست جداولی که باید نادیده گرفته شوند (comma separated) - خالی یعنی همه جداول
EXCLUDE_TABLES=

# لیست جداولی که فقط آن‌ها باید منتقل شوند (comma separated) - خالی یعنی همه جداول
INCLUDE_TABLES=

# مسیر فایل state برای قابلیت Resume
STATE_FILE=/app/logs/migration_state.json

# مسیر فایل لاگ
LOG_FILE=/app/logs/migration.log

# سطح لاگ: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=ERROR

# اگر true باشد، هنگام برخورد با خطا در یک جدول، migration کل متوقف می‌شود
STOP_ON_ERROR=false

# سایز connect timeout به ثانیه
CONNECT_TIMEOUT=30
